root = true

[*]
charset = utf-8
end_of_line = lf

indent_size = 2
indent_style = space

insert_final_newline = true
trim_trailing_whitespace = true

[*.json]
indent_size = 2
max_line_length = unset

[{Makefile*,*.mk}]
indent_size = unset
indent_style = tab
trim_trailing_whitespace = false

[*.md]
max_line_length = 90
trim_trailing_whitespace = false
x-soft-wrap-text = true

[*.py]
indent_size = 4

[*.toml]
indent_size = 4

[*.{yaml,yml}]
max_line_length = 90
