root = true

[*]
charset = utf-8
end_of_line = lf

indent_size = 2
indent_style = space

insert_final_newline = true
max_line_length = 100
spelling_lan = en-US
trim_trailing_whitespace = true

[*.{json,jsonc,json5}]
indent_size = 2
max_line_length = unset

[**/.{devcontainer,vscode}/*.json]
indent_size = 4
max_line_length = unset

[LICENSE]
insert_final_newline = false

[{Makefile*,*.mk}]
indent_size = unset
indent_style = tab
trim_trailing_whitespace = false

[*.md]
max_line_length = 90
trim_trailing_whitespace = false
x-soft-wrap-text = true

[*.py]
indent_size = 4
max_line_length = 90

[*.toml]
indent_size = 4

[*.{yaml,yml}]
max_line_length = 90
